<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BookTracker2.Models"
             x:Class="BookTracker2.Views.BookDetailPage"
             Title="Book Details">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save"
                     Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}" />

            <Label Text="Title" />
            <Entry Text="{Binding Title}"
                   Placeholder="Book title" />

            <Label Text="ISBN" />
            <Grid ColumnDefinitions="*, Auto">
                <Entry Grid.Column="0"
                   Text="{Binding ISBN}"
                   Placeholder="ISBN (optional)"
                   Keyboard="Numeric" 
                   HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                    Text="Lookup"
                    Command="{Binding LookupISBNCommand}" />
            </Grid>

            <Label Text="Author" />
            <Entry Text="{Binding AuthorSearch}"
                   Placeholder="Search or enter author name" />
            <CollectionView ItemsSource="{Binding FilteredAuthors}"
                            IsVisible="{Binding ShowAuthorSuggestions}"
                            MaximumHeightRequest="150"
                            SelectionMode="Single"
                            SelectionChanged="OnAuthorSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Author">
                        <Label Text="{Binding Name}"
                               Padding="8" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Genre" />
            <Entry Text="{Binding GenreSearch}"
                   Placeholder="Search or enter genre name" />
            <CollectionView ItemsSource="{Binding FilteredGenres}"
                            IsVisible="{Binding ShowGenreSuggestions}"
                            MaximumHeightRequest="150"
                            SelectionMode="Single"
                            SelectionChanged="OnGenreSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Genre">
                        <Label Text="{Binding Name}"
                               Padding="8" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Status" />
            <Picker Title="Select status"
                    x:Name="StatusPicker"
                    SelectedIndexChanged="OnStatusSelectedIndexChanged" />

            <Label Text="Format" />
            <Picker Title="Select format (optional)"
                    x:Name="FormatPicker"
                    SelectedIndexChanged="OnFormatSelectedIndexChanged" />

            <Label Text="Rating (optional)" />
            <Picker Title="Select rating (optional)"
                    x:Name="RatingPicker"
                    SelectedIndexChanged="OnRatingSelectedIndexChanged" />

            <Label Text="Comment" />
            <Editor Text="{Binding Comment}"
                    Placeholder="Notes or comments (optional)"
                    HeightRequest="100" />

            <Button Text="Delete Book"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditing}"
                    TextColor="White"
                    BackgroundColor="#C21807" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>