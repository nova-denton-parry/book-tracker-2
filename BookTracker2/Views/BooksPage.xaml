<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BookTracker2.Models"
             x:Class="BookTracker2.Views.BooksPage"
             Title="My Books">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Filter"
                     Command="{Binding ToggleFiltersCommand}" />
        <ToolbarItem Text="Add Book"
                     Command="{Binding NavigateToAddBookCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">

        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}" />

        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding ShowFilters}"
                             Padding="16"
                             Spacing="8">

            <SearchBar Placeholder="Search by title..."
                       Text="{Binding SearchText}" />

            <Picker Title="Filter by status"
                    x:Name="StatusFilterPicker"
                    SelectedIndexChanged="OnStatusFilterChanged" />

            <Picker Title="Filter by format"
                    x:Name="FormatFilterPicker"
                    SelectedIndexChanged="OnFormatFilterChanged" />

            <Picker Title="Filter by author"
                    ItemsSource="{Binding Authors}"
                    ItemDisplayBinding="{Binding Name}"
                    x:Name="AuthorFilterPicker"
                    SelectedIndexChanged="OnAuthorFilterChanged" />

            <Picker Title="Filter by genre"
                    ItemsSource="{Binding Genres}"
                    ItemDisplayBinding="{Binding Name}"
                    x:Name="GenreFilterPicker"
                    SelectedIndexChanged="OnGenreFilterChanged" />

            <Button Text="Clear Filters"
                    Command="{Binding ClearFiltersCommand}" />

        </VerticalStackLayout>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredBooks}">
            <CollectionView.EmptyView>
                <Label Text="No books yet. Tap 'Add Book' to get started!"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <Grid Padding="16" ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Title}"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Status}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Edit"
                                CommandParameter="{Binding BookId}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToEditBookCommand}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>